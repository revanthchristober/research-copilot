<% content_for :title, @question.body[0..60] %>

<div class="mb-6">
  <%= link_to "← Ask another", questions_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
</div>

<div class="bg-white border border-slate-200 rounded-lg p-5 mb-4">
  <p class="text-xs text-slate-500 uppercase tracking-wide mb-1">Question</p>
  <p class="text-lg text-slate-900 font-medium leading-snug"><%= @question.body %></p>
  <p class="text-xs text-slate-500 mt-2"><%= time_ago_in_words(@question.asked_at) %> ago</p>
</div>

<%= turbo_frame_tag "answer_#{@question.id}", src: question_answer_path(@question), loading: "lazy" do %>
  <div class="bg-white border border-slate-200 rounded-lg p-5">
    <div class="flex items-center gap-3 text-sm text-slate-500">
      <svg class="animate-spin h-4 w-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" stroke-linecap="round"/>
      </svg>
      <span>Searching interviews and synthesising an answer…</span>
    </div>
    <p class="text-xs text-slate-400 mt-3">gpt-4o is reading 8 most relevant interview chunks. Usually takes 3–5 seconds.</p>
  </div>
<% end %>
