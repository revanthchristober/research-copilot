<% content_for :title, "Ask" %>

<div class="mb-6">
  <%= link_to "← All questions", questions_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
  <h1 class="text-2xl font-semibold tracking-tight mt-2">Ask your research</h1>
</div>

<%= form_with model: @question, url: questions_path, local: true, class: "bg-white border border-slate-200 rounded-lg p-5" do |f| %>
  <% if @question.errors.any? %>
    <div class="rounded-md bg-rose-50 border border-rose-200 text-rose-800 px-4 py-2 text-sm mb-3">
      <%= @question.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= f.label :body, "Research question", class: "block text-sm font-medium text-slate-700 mb-1" %>
  <%= f.text_area :body, rows: 3, required: true,
        placeholder: "e.g. What are the top onboarding frustrations?",
        class: "w-full rounded-md border-slate-300 focus:border-emerald-500 focus:ring-emerald-500 text-sm" %>
  <div class="mt-3 flex items-center justify-end">
    <%= f.submit "Ask →",
          class: "inline-flex items-center px-4 py-2 rounded-md bg-slate-900 text-white text-sm font-medium hover:bg-slate-800 cursor-pointer" %>
  </div>
<% end %>
