<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Research Copilot" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-slate-50 text-slate-900 antialiased min-h-screen">
    <header class="border-b border-slate-200 bg-white">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center gap-6">
        <%= link_to root_path, class: "flex items-center gap-2 font-semibold shrink-0" do %>
          <span class="inline-block w-2 h-2 rounded-full bg-emerald-500"></span>
          <span>Research Copilot</span>
        <% end %>

        <%= form_with url: search_path, method: :get, local: true, class: "flex-1 max-w-xl" do |f| %>
          <div class="relative">
            <%= f.search_field :q, value: (defined?(@query) ? @query : nil), placeholder: "Search across all interviews…",
                  class: "w-full rounded-md border-slate-300 text-sm pl-9 focus:border-emerald-500 focus:ring-emerald-500" %>
            <svg class="absolute left-2.5 top-2.5 h-4 w-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 3.62 9.685l3.847 3.847a.75.75 0 1 0 1.06-1.06l-3.847-3.847A5.5 5.5 0 0 0 9 3.5ZM5 9a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z" clip-rule="evenodd"/>
            </svg>
          </div>
        <% end %>

        <nav class="text-sm text-slate-500 ml-auto shrink-0 flex items-center gap-4">
          <%= link_to "Ask", questions_path, class: "hover:text-slate-900" %>
          <%= link_to "Themes", themes_path, class: "hover:text-slate-900" %>
          <%= link_to "Transcripts", transcripts_path, class: "hover:text-slate-900" %>
        </nav>
      </div>
    </header>

    <% if notice %>
      <div class="max-w-5xl mx-auto px-6 mt-4">
        <div class="rounded-md bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-2 text-sm"><%= notice %></div>
      </div>
    <% end %>

    <main class="max-w-5xl mx-auto px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
